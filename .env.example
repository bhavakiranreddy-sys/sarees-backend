# ──────────────────────────────────────────────────────────────────────────────
# B2B Saree Marketplace — environment variable reference
#
# Copy this file to `.env` and fill in the values for your local environment.
# Never commit your real `.env` file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# For Supabase, find this in: Project Settings → Database → Connection string
# Use the "URI" format and replace [YOUR-PASSWORD] with your database password.
#
# Supabase (production / staging):
#   DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
#
# Local PostgreSQL (Docker or native install):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saree_marketplace
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Secret key used to sign JWT tokens.
# Generate a strong random value with:  openssl rand -hex 32
SECRET_KEY=replace-me-with-a-long-random-secret

# JWT signing algorithm — HS256 is the default and works for most cases.
ALGORITHM=HS256

# How long (in minutes) an access token remains valid.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# How long (in days) a refresh token remains valid.
REFRESH_TOKEN_EXPIRE_DAYS=7
